<?xml version="1.0" encoding="utf-8"?>
<!--
  Default run settings for TapeNET test suite.
  Excludes resource-intensive large-file tests (multi-GB) from routine runs.

  To run ALL tests including large-file tests:
    dotnet test - -settings TapeNET.runsettings - -filter "Category=LargeFile" (large only)
    dotnet test  (no - -settings flag → no filter → runs everything)

  Visual Studio: Test Explorer → gear icon → select/deselect this .runsettings file.
-->
<RunSettings>
  <RunConfiguration>
    <TestCaseFilter>Category!=LargeFile</TestCaseFilter>
  </RunConfiguration>
</RunSettings>
