<Window x:Class="TapeWinNET.FormatMediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        xmlns:help="clr-namespace:TapeWinNET.Help"
        xmlns:controls="clr-namespace:TapeWinNET.Controls"
        d:DataContext="{d:DesignInstance Type=vm:FormatMediaViewModel}"
        mc:Ignorable="d"
        Title="Format Media"
        Height="300" Width="450"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <!-- Outer grid: column 0 = dialog content, column 1 = splitter, column 2 = help pane. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>                                       <!-- help splitter -->
            <ColumnDefinition x:Name="HelpPaneColumn" Width="0" MinWidth="0"/>    <!-- help pane    -->
        </Grid.ColumnDefinitions>

        <!-- Dialog content fills column 0 -->
        <Grid x:Name="HelpOverlayRoot" Grid.Column="0" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Media Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16"
                    help:HelpControlNameAttachedProperty.ControlName="Media description">
            <TextBlock Text="Media Description:" Margin="0,0,0,4"/>
            <TextBox Text="{Binding MediaName, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Initiator Partition Option -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8"
                    help:HelpControlNameAttachedProperty.ControlName="Create initiator partition">
            <CheckBox Content="Create initiator partition for TOC"
                      IsChecked="{Binding CreateInitiatorPartition}"
                      IsEnabled="{Binding SupportsInitiatorPartition}"
                      Margin="0,0,0,4"/>
            <TextBlock Text="{Binding InitiatorPartitionHint}"
                       FontSize="10" Foreground="DarkGray"
                       TextWrapping="Wrap"
                       Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Warning Panel -->
        <Border Grid.Row="2" Style="{StaticResource WarningPanelStyle}" VerticalAlignment="Bottom">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding WarningLevel, Converter={x:Static converters:WarningLevelToIconConverter.Instance}}"
                           FontSize="13" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding WarningMessage}" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="HelpButton" Content="_Help ▶" Click="HelpButton_Click"
                        MinWidth="60" Padding="10,1"
                        ToolTip="Open help for this dialog (F1)"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Width="80" Margin="0,0,8,0" IsCancel="True" IsDefault="True"/>
                <Button Content="Format" Command="{Binding FormatCommand}"
                        Width="80" Foreground="{DynamicResource WarningFg.Error}"
                        help:HelpControlNameAttachedProperty.ControlName="Format button"/>
            </StackPanel>
        </Grid>
        </Grid><!-- end dialog-content Grid (column 0) -->

        <!-- Help splitter — visible only when the help pane is open -->
        <GridSplitter x:Name="HelpPaneSplitter"
                      Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="LightGray"
                      Visibility="Collapsed"/>

        <!-- Help pane — width driven by HelpPaneColumn; starts at 0 (hidden) -->
        <controls:HelpPane x:Name="HelpPaneControl"
                           Grid.Column="2"
                           DataContext="{x:Null}"
                           Visibility="Collapsed"/>

    </Grid>
</Window>
