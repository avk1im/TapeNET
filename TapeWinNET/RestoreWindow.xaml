<Window x:Class="TapeWinNET.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        xmlns:help="clr-namespace:TapeWinNET.Help"
        xmlns:controls="clr-namespace:TapeWinNET.Controls"
        d:DataContext="{d:DesignInstance Type=vm:RestoreViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="820" Height="620"
        MinWidth="650" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityIcon" DimmedOpacity="0.4"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityText" DimmedOpacity="0.6"/>
    </Window.Resources>

    <!-- Outer grid: column 0 = dialog content, column 1 = splitter, column 2 = help pane.
         The window Width is expanded when the help pane opens so dialog content is undisturbed. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>                                       <!-- help splitter -->
            <ColumnDefinition x:Name="HelpPaneColumn" Width="0" MinWidth="0"/>    <!-- help pane    -->
        </Grid.ColumnDefinitions>

        <!-- Dialog content fills column 0 -->
        <Grid Grid.Column="0" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main content: 2-column layout with splitter -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Backup sets summary table -->
            <GroupBox Grid.Column="0" Header="{Binding ItemsGroupHeader}" Margin="0,0,4,0"
                      help:HelpTopicIdAttachedProperty.TopicId="dialog.restore.sets">
                <ListView ItemsSource="{Binding BackupSets}"
                          CheckBox.Checked="ItemCheckBox_Changed"
                          CheckBox.Unchecked="ItemCheckBox_Changed"
                          CheckBox.Indeterminate="ItemCheckBox_Changed"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          Margin="4">
                    <ListView.View>
                        <GridView>
                            <!-- Checkbox column -->
                            <GridViewColumn Width="28">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding DataContext.AreAllSetsChecked,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                  IsThreeState="True"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  ToolTip="Select / deselect all"/>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsCheckedForRestore, Mode=TwoWay}"
                                                  IsThreeState="{Binding HasPartialSelection}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- Icon column, dimmed for off-volume sets -->
                            <GridViewColumn Width="28">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Width="16" Height="16" Source="{Binding Icon}"
                                               Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityIcon}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Set #" Width="55">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IndexDisplay}"
                                                   Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Description" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}"
                                                   Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Selected" Width="65">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SelectedFileCountFormatted}"
                                                   Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Files" Width="55">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileCountFormatted}"
                                                   Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Size" Width="65">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalSizeFormatted}"
                                                   Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Inc?" Width="38">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IncrementalDisplay}"
                                                   Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="LightGray"/>

            <!-- Right: Options panel -->
            <ScrollViewer Grid.Column="2" Margin="4,0,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Operation Selection -->
                <GroupBox Header="Operation" Margin="0,0,0,8"
                          help:HelpTopicIdAttachedProperty.TopicId="dialog.restore.operation">
                    <StackPanel Margin="8">
                        <RadioButton Content="Restore"
                                     IsChecked="{Binding IsRestoreMode}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Validate"
                                     IsChecked="{Binding IsValidateMode}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Verify"
                                     IsChecked="{Binding IsVerifyMode}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Restore To -->
                <GroupBox Header="Restore to" Margin="0,0,0,8"
                          IsEnabled="{Binding IsRestoreToEnabled}"
                          help:HelpTopicIdAttachedProperty.TopicId="dialog.restore.destination">
                    <StackPanel Margin="8">
                        <RadioButton Content="Original location"
                                     IsChecked="{Binding RestoreToOriginal}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Target folder:"
                                     IsChecked="{Binding RestoreToTargetDir}"
                                     Margin="0,0,0,4"/>
                        <Grid Margin="20,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     IsEnabled="{Binding IsTargetDirectoryInputEnabled}"
                                     Margin="0,0,4,0"/>
                            <Button Grid.Column="1"
                                    Content="..."
                                    Command="{Binding BrowseTargetCommand}"
                                    IsEnabled="{Binding IsTargetDirectoryInputEnabled}"
                                    Width="28" Padding="0"/>
                        </Grid>
                        <CheckBox Content="Restore with subfolders"
                                  IsChecked="{Binding RecurseSubdirectories}"
                                  IsEnabled="{Binding IsRecurseSubdirsEnabled}"
                                  Margin="20,4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Options -->
                <GroupBox Header="Options" help:HelpTopicIdAttachedProperty.TopicId="dialog.restore.options">
                    <StackPanel Margin="8">
                        <CheckBox Content="Include incremental chain"
                                  IsChecked="{Binding Incremental}"
                                  Margin="0,0,0,4"
                                  ToolTip="Process files from all backup sets of the incremental chain"/>
                            <CheckBox Content="This volume only"
                                  IsChecked="{Binding NoMultivolume}"
                                  IsEnabled="{Binding IsNoMultivolumeEnabled}"
                                  Margin="0,4,0,4"
                                  ToolTip="Confine operation to backup sets on the current volume"/>
                        <CheckBox Content="Uncheck processed files"
                                  IsChecked="{Binding UncheckProcessedFiles}"
                                  Margin="0,4,0,8"
                                  ToolTip="After the operation, uncheck successfully processed files; leave unprocessed ones checked"/>
                        <TextBlock Text="Handle existing:" Margin="0,0,0,4"
                                   IsEnabled="{Binding IsHandleExistingEnabled}"/>
                        <ComboBox ItemsSource="{Binding HandleExistingOptions}"
                                  SelectedItem="{Binding SelectedHandleExisting}"
                                  IsEnabled="{Binding IsHandleExistingEnabled}"
                                  Margin="0,0,0,8"/>

                        <!-- Handle-existing warning -->
                        <Border Style="{StaticResource WarningPanelStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding WarningLevel, Converter={x:Static converters:WarningLevelToIconConverter.Instance}}"
                                           FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding WarningMessage}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <CheckBox Content="Skip all errors"
                                IsChecked="{Binding SkipAllErrors}"
                                ToolTip="Silently skip all file errors without prompting (unattended mode)"
                                Margin="0,4,0,0"/>
                        </StackPanel>
                </GroupBox>

                <!-- Preview -->
                <GroupBox Header="Preview" Margin="0,8,0,0">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Total files:" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewTotalFiles}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total size:" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewTotalSize}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Multivolume:" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewMultivolume}"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Remove Unchecked"
                        Command="{Binding RemoveUncheckedSetsCommand}"
                        Width="120"
                        ToolTip="Remove all unchecked backup sets from the list"
                        Margin="0,0,8,0"/>
                <Button Content="_Help"
                        Click="HelpButton_Click"
                        Width="60"
                        ToolTip="Open help for this dialog (F1)"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Width="80"
                        Margin="0,0,8,0"/>
                <Button Content="{Binding ActionButtonText}"
                        Command="{Binding StartCommand}"
                        IsDefault="True"
                        Width="100"/>
            </StackPanel>
        </Grid>
        </Grid><!-- end dialog-content Grid (column 0) -->

        <!-- Help splitter — visible only when the help pane is open -->
        <GridSplitter x:Name="HelpPaneSplitter"
                      Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="LightGray"
                      Visibility="Collapsed"/>

        <!-- Help pane — width driven by HelpPaneColumn; starts at 0 (hidden) -->
        <controls:HelpPane x:Name="HelpPaneControl"
                           Grid.Column="2"
                           Visibility="Collapsed"/>

    </Grid>
</Window>
