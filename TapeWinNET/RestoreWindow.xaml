<Window x:Class="TapeWinNET.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        d:DataContext="{d:DesignInstance Type=vm:RestoreViewModel}"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Width="720" Height="420"
        MinWidth="600" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main content: 2-column layout -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Backup sets summary table -->
            <GroupBox Grid.Column="0" Header="{Binding ItemsGroupHeader}" Margin="0,0,12,0">
                <ListView ItemsSource="{Binding BackupSets}"
                          CheckBox.Checked="ItemCheckBox_Changed"
                          CheckBox.Unchecked="ItemCheckBox_Changed"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          Margin="4">
                    <ListView.View>
                        <GridView>
                            <!-- Checkbox column -->
                            <GridViewColumn Width="28">
                                <GridViewColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding DataContext.AreAllSetsChecked,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                  IsThreeState="True"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  ToolTip="Select / deselect all"/>
                                    </DataTemplate>
                                </GridViewColumn.HeaderTemplate>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsCheckedForRestore, Mode=TwoWay}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <!-- Icon column -->
                            <GridViewColumn Width="28">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Width="16" Height="16" Source="{Binding Icon}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Set #" Width="55"
                                            DisplayMemberBinding="{Binding IndexDisplay}"/>
                            <GridViewColumn Header="Description" Width="120"
                                            DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Selected" Width="65"
                                            DisplayMemberBinding="{Binding SelectedFileCountFormatted}"/>
                            <GridViewColumn Header="Files" Width="55"
                                            DisplayMemberBinding="{Binding FileCountFormatted}"/>
                            <GridViewColumn Header="Size" Width="65"
                                            DisplayMemberBinding="{Binding TotalSizeFormatted}"/>
                            <GridViewColumn Header="Inc?" Width="38"
                                            DisplayMemberBinding="{Binding IncrementalDisplay}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Right: Options panel -->
            <StackPanel Grid.Column="1" Width="240">
                <!-- Operation Selection -->
                <GroupBox Header="Operation" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <RadioButton Content="Restore"
                                     IsChecked="{Binding IsRestoreMode}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Validate"
                                     IsChecked="{Binding IsValidateMode}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Verify"
                                     IsChecked="{Binding IsVerifyMode}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Restore To -->
                <GroupBox Header="Restore to" Margin="0,0,0,8"
                          IsEnabled="{Binding IsRestoreToEnabled}">
                    <StackPanel Margin="8">
                        <RadioButton Content="Original location"
                                     IsChecked="{Binding RestoreToOriginal}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Target directory:"
                                     IsChecked="{Binding RestoreToTargetDir}"
                                     Margin="0,0,0,4"/>
                        <Grid Margin="20,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     IsEnabled="{Binding IsTargetDirectoryInputEnabled}"
                                     Margin="0,0,4,0"/>
                            <Button Grid.Column="1"
                                    Content="..."
                                    Command="{Binding BrowseTargetCommand}"
                                    IsEnabled="{Binding IsTargetDirectoryInputEnabled}"
                                    Width="28" Padding="0"/>
                        </Grid>
                        <CheckBox Content="Include subdirectories"
                                  IsChecked="{Binding RecurseSubdirectories}"
                                  IsEnabled="{Binding IsRecurseSubdirsEnabled}"
                                  Margin="20,4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Options -->
                <GroupBox Header="Options">
                    <StackPanel Margin="8">
                        <CheckBox Content="Include incremental chain"
                                  IsChecked="{Binding Incremental}"
                                  Margin="0,0,0,6"/>
                        <TextBlock Text="Handle existing:" Margin="0,0,0,4"
                                   IsEnabled="{Binding IsHandleExistingEnabled}"/>
                        <ComboBox ItemsSource="{Binding HandleExistingOptions}"
                                  SelectedItem="{Binding SelectedHandleExisting}"
                                  IsEnabled="{Binding IsHandleExistingEnabled}"/>

                        <!-- Handle-existing warning -->
                        <Border Style="{StaticResource WarningPanelStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding WarningLevel, Converter={x:Static converters:WarningLevelToIconConverter.Instance}}"
                                           FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding WarningMessage}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="80"
                    Margin="0,0,8,0"/>
            <Button Content="{Binding ActionButtonText}"
                    Command="{Binding StartCommand}"
                    IsDefault="True"
                    Width="100"/>
        </StackPanel>
    </Grid>
</Window>
