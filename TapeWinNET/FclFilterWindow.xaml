<Window x:Class="TapeWinNET.FclFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:controls="clr-namespace:TapeWinNET.Controls"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        d:DataContext="{d:DesignInstance Type=vm:FclFilterWindowVM}"
        mc:Ignorable="d"
        Title="Advanced Filter"
        Height="360" Width="570"
        MinHeight="250" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <converters:BoolToVisibilityCollapsedConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- Main content area -->
            <RowDefinition Height="Auto"/>  <!-- Sync buttons -->
            <RowDefinition Height="Auto"/>  <!-- AI input panel -->
            <RowDefinition Height="Auto"/>  <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Main content: Visual (left) + Program (right)  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>  <!-- splitter -->
                <ColumnDefinition x:Name="ProgramColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Left pane: Visual DNF editor ─── -->
            <GroupBox Grid.Column="0" Header="Conditions" Margin="0,0,2,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scrollable condition groups -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:FclConditionGroupVM}">
                                    <controls:FclConditionGroup Margin="0,0,0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- + Add group (OR) -->
                    <Button Grid.Row="1" Content="+ Add group (OR)"
                            Command="{Binding AddGroupCommand}"
                            HorizontalAlignment="Left"
                            Margin="4,4,0,4" Padding="8,2"
                            FontSize="11" Foreground="Gray"
                            ToolTip="Add an OR-connected group of conditions">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Cursor="Hand"
                                           TextDecorations="Underline"
                                           Foreground="{TemplateBinding Foreground}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Non-DNF overlay (when text-edited FCL can't be shown visually) -->
                    <Border Grid.Row="0" Grid.RowSpan="2"
                            Background="#F0F0F0" Padding="16"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDnfCompatible}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="ℹ The FCL program cannot be displayed visually."
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding NonDnfMessage}" TextWrapping="Wrap"
                                       Foreground="Gray" MaxWidth="280"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- Splitter between panes -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="LightGray"
                          Visibility="{Binding IsProgramPaneOpen, Converter={StaticResource BoolToVis}}"/>

            <!-- ─── Right pane: FCL Program ─── -->
            <GroupBox Grid.Column="2" Header="{Binding ProgramPaneHeader}"
                      Visibility="{Binding IsProgramPaneOpen, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>   <!-- Text editor -->
                        <RowDefinition Height="Auto"/> <!-- Validation summary -->
                        <RowDefinition Height="Auto" MaxHeight="120"/> <!-- Diagnostics list -->
                    </Grid.RowDefinitions>

                    <!-- FCL text editor -->
                    <TextBox Grid.Row="0"
                             x:Name="ProgramTextBox"
                             Text="{Binding FclText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             IsInactiveSelectionHighlightEnabled="True"
                             FontFamily="Consolas" FontSize="12"
                             Padding="4">
                        <TextBox.Resources>
                            <!-- Orange highlight for diagnostic spans (visible even when TextBox is unfocused) -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                             Color="#FF8C00" Opacity="0.3"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                             Color="Black"/>
                        </TextBox.Resources>
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <!-- Subtle left-border highlight when text has been manually modified -->
                                    <DataTrigger Binding="{Binding IsFclTextModified}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF8C00"/>
                                        <Setter Property="BorderThickness" Value="2,1,1,1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Validation summary -->
                    <TextBlock Grid.Row="1" Text="{Binding ValidationSummary}"
                               Margin="0,4,0,2" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Green"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                        <Setter Property="Foreground" Value="#CC0000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Diagnostics list -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Diagnostics}"
                             SelectedItem="{Binding SelectedDiagnostic}"
                             Visibility="{Binding HasErrors, Converter={StaticResource BoolToVis}}"
                             FontFamily="Consolas" FontSize="11"
                             BorderThickness="1" BorderBrush="LightGray"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}: {2}">
                                            <Binding Path="Severity"/>
                                            <Binding Path="Code"/>
                                            <Binding Path="Message"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Sync buttons (between the two panes)           -->
        <!-- ═══════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,4">
            <Button Content="Update →"
                    Command="{Binding ApplyVisualToTextCommand}"
                    Width="80" Margin="0,0,8,0"
                    ToolTip="Build FCL text from the visual conditions"
                    Visibility="{Binding IsProgramPaneOpen, Converter={StaticResource BoolToVis}}"/>
            <Button Content="← Apply"
                    Command="{Binding ApplyTextToVisualCommand}"
                    Width="80"
                    ToolTip="Parse FCL text and populate the visual editor"
                    Visibility="{Binding IsProgramPaneOpen, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  AI input panel (collapsible)                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="0,8,0,0"
                Padding="8"
                Background="#FFF6F8FC"
                BorderBrush="#FFB9C4D6" BorderThickness="1"
                CornerRadius="4"
                Visibility="{Binding IsAiPanelOpen, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Describe the files to filter in plain language:"
                           FontSize="11" Foreground="#FF40506B"
                           Margin="0,0,0,4"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding AiPromptText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Padding="4,3"
                             ToolTip="e.g. 'photos from the last week but not RAW files'">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SubmitAiPromptCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Content="Generate"
                            Command="{Binding SubmitAiPromptCommand}"
                            Width="80" Margin="8,0,0,0"
                            ToolTip="Translate the description into FCL using AI"/>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="{Binding AiStatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Margin="0,4,0,0"
                           Visibility="{Binding HasAiStatus, Converter={StaticResource BoolToVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF40506B"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AiStatusLevel}" Value="Error">
                                    <Setter Property="Foreground" Value="{StaticResource WarningFg.Error}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AiStatusLevel}" Value="Failed">
                                    <Setter Property="Foreground" Value="{StaticResource WarningFg.Failed}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AiStatusLevel}" Value="Warning">
                                    <Setter Property="Foreground" Value="{StaticResource WarningFg.Warning}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AiStatusLevel}" Value="Completed">
                                    <Setter Property="Foreground" Value="{StaticResource WarningFg.Completed}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Bottom bar                                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Show/Hide Program toggle -->
            <Button Grid.Column="0"
                    Content="{Binding ToggleProgramPaneText}"
                    Command="{Binding ToggleProgramPaneCommand}"
                    Margin="0,0,8,0"/>

            <!-- AI-assisted generation toggle -->
            <Button Grid.Column="1"
                    Command="{Binding GenerateWithAiCommand}"
                    ToolTip="Describe the filter in plain language and let AI generate the FCL">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✦" FontSize="14" Margin="0,0,4,0"/>
                    <TextBlock Text="AI Generate…"/>
                </StackPanel>
            </Button>

            <!-- Right-aligned action buttons -->
            <Button Grid.Column="3"
                    Content="Clear Filter"
                    Command="{Binding ClearFilterCommand}"
                    Width="80" Margin="0,0,8,0"
                    ToolTip="Remove the filter definition entirely"/>
            <Button Grid.Column="4"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="80" Margin="0,0,8,0"/>

            <!-- "All sets" checkbox — visible only when multiple sets exist -->
            <CheckBox Grid.Column="5"
                      Content="all sets"
                      IsChecked="{Binding ApplyToAll}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      ToolTip="Apply or disable the filter for all backup sets on this tape"
                      Visibility="{Binding HasMultipleSets,
                                   Converter={StaticResource BoolToVis}}"/>

            <Button Grid.Column="6"
                    Content="Apply"
                    Command="{Binding ApplyFilterCommand}"
                    IsDefault="True"
                    Width="80"/>
        </Grid>
    </Grid>
</Window>
