<Window x:Class="TapeWinNET.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:models="clr-namespace:TapeWinNET.Models"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        xmlns:controls="clr-namespace:TapeWinNET.Controls"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="F2" Command="{Binding RenameSelectedCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <converters:BoolToVisibilityCollapsedConverter x:Key="BoolToVis" />
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityIcon" DimmedOpacity="0.4"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityText" DimmedOpacity="0.6"/>

        <!-- Context menu: Drive node (DataContext is TapeTreeItemViewModel, so bind to window) -->
        <ContextMenu x:Key="DriveContextMenu" x:Shared="False"
                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="Open _Drive" ItemsSource="{Binding DriveMenuItems}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Header}"/>
                        <Setter Property="Command" Value="{Binding Command}"/>
                        <Setter Property="CommandParameter" Value="{Binding DriveNumber}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
            <MenuItem Header="Open _Virtual Drive..." Command="{Binding OpenVirtualDriveCommand}"/>
            <MenuItem Header="Recent Virtual Drives" ItemsSource="{Binding RecentVirtualDriveMenuItems}"
                      Visibility="{Binding HasRecentVirtualDrives, Converter={StaticResource BoolToVis}}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Header}"/>
                        <Setter Property="Command" Value="{Binding Command}"/>
                        <Setter Property="CommandParameter" Value="{Binding DriveNumber}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
        </ContextMenu>

        <!-- Context menu: Media (Tape) node -->
        <ContextMenu x:Key="MediaContextMenu" x:Shared="False"
                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="_New Backup..." Command="{Binding NewBackupCommand}"/>
            <MenuItem Header="Restore _All Sets..." Command="{Binding RestoreAllSetsCommand}"/>
            <Separator/>
            <MenuItem Header="Re_name..." Command="{Binding RenameSelectedCommand}"/>
            <MenuItem Header="_Reread TOC" Command="{Binding RereadTOCCommand}"/>
            <Separator/>
            <MenuItem Header="E_xport TOC to File..." Command="{Binding ExportTOCCommand}"/>
            <MenuItem Header="_Import TOC from File..." Command="{Binding ImportTOCCommand}"/>
            <Separator/>
            <MenuItem Header="_Eject" Command="{Binding EjectCommand}"/>
            <Separator/>
            <MenuItem Header="_Delete Backup Sets..." Command="{Binding DeleteBackupSetsCommand}"/>
            <MenuItem Header="_Format..." Command="{Binding FormatMediaCommand}"/>
        </ContextMenu>

        <!-- Context menu: Backup set / Restore actions (shared by TreeView and ListViews) -->
        <ContextMenu x:Key="RestoreContextMenu" x:Shared="False"
                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="{Binding RestoreCommandText}" Command="{Binding RestoreCommand}"/>
            <MenuItem Header="{Binding ValidateCommandText}" Command="{Binding ValidateCommand}"/>
            <MenuItem Header="{Binding VerifyCommandText}" Command="{Binding VerifyCommand}"/>
            <Separator/>
            <MenuItem Header="Re_name..." Command="{Binding RenameSelectedCommand}"/>
        </ContextMenu>

        <!-- TreeView item style -->
        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <!-- Pass window DataContext to context menus via Tag (context menus are outside the visual tree) -->
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ItemType}" Value="Drive">
                    <Setter Property="ContextMenu" Value="{StaticResource DriveContextMenu}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ItemType}" Value="Tape">
                    <Setter Property="ContextMenu" Value="{StaticResource MediaContextMenu}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ItemType}" Value="BackupSet">
                    <Setter Property="ContextMenu" Value="{StaticResource RestoreContextMenu}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- TreeView item template with icons -->
        <HierarchicalDataTemplate x:Key="TreeItemTemplate" 
                                  DataType="{x:Type vm:TapeTreeItemViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <!-- Icon bound to the Icon property, dimmed for off-volume sets -->
                <Image Width="16" Height="16" Margin="0,0,4,0"
                       Source="{Binding Icon}"
                       Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityIcon}}" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ItemType}" Value="Drive">
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ItemType}" Value="Tape">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <!-- In-memory info (blue) — listed before IsTOCFromFile so TOC warning takes precedence -->
                                <DataTrigger Binding="{Binding IsInMemory}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource WarningFg.Info}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsTOCFromFile}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource WarningFg.Failed}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </HierarchicalDataTemplate>
        
        <!-- ListBox virtualization style to improve ListBox performance -->
        <Style x:Key="VirtualizedListBoxStyle" TargetType="ListBox">
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="LogPaneRow" Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem x:Name="FileMenu" Header="_File">
                <MenuItem Header="Open _Drive" ItemsSource="{Binding DriveMenuItems}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Header}"/>
                            <Setter Property="Command" Value="{Binding Command}"/>
                            <Setter Property="CommandParameter" Value="{Binding DriveNumber}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="Open _Virtual Drive..." Command="{Binding OpenVirtualDriveCommand}"/>
                <MenuItem Header="Recent Virtual Drives" ItemsSource="{Binding RecentVirtualDriveMenuItems}"
                          Visibility="{Binding HasRecentVirtualDrives, Converter={StaticResource BoolToVis}}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Header}"/>
                            <Setter Property="Command" Value="{Binding Command}"/>
                            <Setter Property="CommandParameter" Value="{Binding DriveNumber}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Virtual _IO Speed" 
                          ItemsSource="{Binding IoSpeedOptions}"
                          Visibility="{Binding IsIoSpeedVisible, Converter={StaticResource BoolToVis}}"
                          IsEnabled="{Binding IsIoSpeedEnabled}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Display}"/>
                            <Setter Property="IsCheckable" Value="True"/>
                            <Setter Property="IsChecked">
                                <Setter.Value>
                                    <MultiBinding Converter="{x:Static converters:EqualityConverter.Instance}" Mode="OneWay">
                                        <Binding/>
                                        <Binding Path="DataContext.SelectedIoSpeed" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Command" Value="{Binding DataContext.SetIoSpeedCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator Visibility="{Binding IsIoSpeedVisible, Converter={StaticResource BoolToVis}}"/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Media">
                <MenuItem Header="Re_name..." Command="{Binding RenameMediaCommand}"/>
                <MenuItem Header="_Reread TOC" Command="{Binding RereadTOCCommand}"/>
                <Separator/>
                <MenuItem Header="E_xport TOC to File..." Command="{Binding ExportTOCCommand}"/>
                <MenuItem Header="_Import TOC from File..." Command="{Binding ImportTOCCommand}"/>
                <Separator/>
                <MenuItem Header="_Eject" Command="{Binding EjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Delete Backup Sets..." Command="{Binding DeleteBackupSetsCommand}"/>
                <MenuItem Header="_Format..." Command="{Binding FormatMediaCommand}"/>
            </MenuItem>
            <MenuItem Header="_Backup">
                <MenuItem Header="_New Backup..." Command="{Binding NewBackupCommand}"/>
                <Separator/>
                <MenuItem Header="_Delete Backup Sets..." Command="{Binding DeleteBackupSetsCommand}"/>
                <Separator Visibility="{Binding IsBackupInProgress, Converter={StaticResource BoolToVis}}"/>
                <MenuItem Header="Abort _Backup" Command="{Binding AbortBackupCommand}"
                          Visibility="{Binding IsBackupInProgress, Converter={StaticResource BoolToVis}}"/>
            </MenuItem>
            <MenuItem Header="_Restore">
                <MenuItem Header="{Binding RestoreCommandText}" Command="{Binding RestoreCommand}"/>
                <MenuItem Header="{Binding ValidateCommandText}" Command="{Binding ValidateCommand}"/>
                <MenuItem Header="{Binding VerifyCommandText}" Command="{Binding VerifyCommand}"/>
                <Separator Visibility="{Binding IsRestoreInProgress, Converter={StaticResource BoolToVis}}"/>
                <MenuItem Header="Abort _Operation" Command="{Binding AbortRestoreCommand}"
                          Visibility="{Binding IsRestoreInProgress, Converter={StaticResource BoolToVis}}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="Show _Full Pathname" 
                          IsCheckable="True" 
                          IsChecked="{Binding ShowFullPathname}"/>
                <MenuItem Header="Show _Incremental Sets" 
                          IsCheckable="True" 
                          IsChecked="{Binding ShowIncrementalSets}"/>
            </MenuItem>
            <MenuItem Header="_Log">
                <MenuItem Header="_Auto-scroll" 
                          IsCheckable="True" 
                          IsChecked="{Binding IsAutoScrollEnabled}"/>
                <MenuItem Header="Show _Timestamps" 
                          IsCheckable="True" 
                          IsChecked="{Binding ShowTimestamps}"/>
                <Separator/>
                <MenuItem Header="_Filter Log" Command="{Binding FocusLogFilterCommand}"/>
                <Separator/>
                <MenuItem Header="_Save Log to File…" Command="{Binding SaveLogCommand}"/>
                <MenuItem Header="{Binding MirrorLogMenuHeader}" Command="{Binding MirrorLogCommand}"/>
                <Separator/>
                <MenuItem Header="_Clear Log" Command="{Binding ClearLogCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreePaneColumn" Width="280" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>
            
            <!-- Tree View Pane -->
            <GroupBox Grid.Column="0" Header="Tape Structure" Margin="4">
                <TreeView ItemsSource="{Binding TreeItems}"
                          ItemTemplate="{StaticResource TreeItemTemplate}"
                          ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          PreviewMouseRightButtonDown="TreeView_PreviewMouseRightButtonDown"
                          PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                          MouseMove="DragSource_MouseMove">
                </TreeView>
            </GroupBox>
            
            <!-- Horizontal Splitter between Tree and Content -->
            <GridSplitter Grid.Column="1" Width="4" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch"
                          Background="LightGray" />
            
            <!-- Content Pane (Properties + Table) -->
            <Grid Grid.Column="2" Margin="4">
                <Grid.RowDefinitions>
                    <!-- Properties subpane (always visible) -->
                    <RowDefinition x:Name="PropertiesPaneRow" Height="150" MinHeight="100" MaxHeight="300" />
                    <!-- Vertical Splitter (visible when table is shown) -->
                    <RowDefinition Height="Auto" />
                    <!-- Table subpane (visible for Media and BackupSet) -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Properties Subpane -->
                <GroupBox Grid.Row="0" Header="{Binding PropertiesHeader}">
                    <ListView ItemsSource="{Binding PropertyList}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Re_name..." Command="{Binding RenameSelectedCommand}"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource WarningFg.Failed}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Property" Width="180"
                                                DisplayMemberBinding="{Binding Property}" />
                                <GridViewColumn Header="Value" Width="280"
                                                DisplayMemberBinding="{Binding Value}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
                
                <!-- Vertical Splitter (only visible when table is shown) -->
                <GridSplitter Grid.Row="1" Height="4" 
                              HorizontalAlignment="Stretch" 
                              VerticalAlignment="Center"
                              Background="LightGray"
                              Visibility="{Binding IsTableVisible, Converter={StaticResource BoolToVis}}" />
                
                <!-- Table Subpane -->
                <GroupBox Grid.Row="2" Header="{Binding TableHeader}"
                          Visibility="{Binding IsTableVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <!-- Files Table + Filter Pane (visible when BackupSet is selected) -->
                        <Grid Visibility="{Binding IsFileTableVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="FileFilterPaneRow" Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListView Grid.Row="0"
                                      ItemsSource="{Binding FileList}"
                                      SelectedItem="{Binding SelectedFile}"
                                      GridViewColumnHeader.Click="GridViewColumnHeader_Click"
                                      CheckBox.Checked="FileCheckBox_Changed"
                                      CheckBox.Unchecked="FileCheckBox_Changed"
                                      PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                                      PreviewMouseLeftButtonUp="FileList_PreviewMouseLeftButtonUp"
                                      MouseMove="DragSource_MouseMove"
                                      Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.View>
                                    <GridView>
                                        <!-- Checkbox column for file-level restore selection -->
                                        <GridViewColumn Width="28">
                                            <GridViewColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding DataContext.AreAllFilesChecked,
                                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                               IsThreeState="True"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               ToolTip="Select / deselect all files"/>
                                                </DataTemplate>
                                            </GridViewColumn.HeaderTemplate>
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsCheckedForRestore, Mode=TwoWay}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <!-- Icon column for files -->
                                        <GridViewColumn Width="30">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Image Width="16" Height="16" Source="{Binding Icon}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" Width="200"
                                                        DisplayMemberBinding="{Binding FileName}" />
                                        <GridViewColumn Header="Size" Width="80"
                                                        DisplayMemberBinding="{Binding SizeFormatted}" />
                                        <GridViewColumn Header="Modified" Width="130"
                                                        DisplayMemberBinding="{Binding LastModified}" />
                                        <GridViewColumn Header="Block" Width="70"
                                                        DisplayMemberBinding="{Binding Block}" />
                                        <GridViewColumn Header="Path" Width="250"
                                                        DisplayMemberBinding="{Binding FullPath}" />
                                    </GridView>
                                </ListView.View>
                                <ListView.ContextMenu>
                                    <StaticResource ResourceKey="RestoreContextMenu"/>
                                </ListView.ContextMenu>
                            </ListView>

                            <!-- Splitter between file list and filter pane (snaps to full / compact / hidden) -->
                            <controls:SnappingGridSplitter Grid.Row="1" Height="4"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Background="LightGray"
                                          TargetIndex="2">
                                <controls:SnappingGridSplitter.SnapZones>
                                    <!-- Hidden: catches everything from 0 up to 14px -->
                                    <controls:SnapZone Value="0"  LowerRange="9999" UpperRange="12"/>
                                    <!-- Compact (button row only): catches 14–36px range -->
                                    <controls:SnapZone Value="26" LowerRange="16"   UpperRange="8"/>
                                    <!-- Full (natural size): catches 8px below measured height and above -->
                                    <controls:SnapZone IsAutoSize="True" LowerRange="8" UpperRange="9999"/>
                                </controls:SnappingGridSplitter.SnapZones>
                            </controls:SnappingGridSplitter>

                            <!-- File Filter Pane -->
                            <controls:FileFilterPane Grid.Row="2"
                                                     x:Name="FileFilterPaneControl"
                                                     TotalCount="{Binding FileTotalCount}"
                                                     FilteredCount="{Binding FileFilteredCount}"
                                                     IsFilterActive="{Binding IsFileFilterActive}"/>
                        </Grid>

                        <!-- Backup Sets Table (visible when Media is selected) -->
                        <ListView ItemsSource="{Binding BackupSetList}"
                                  SelectedItem="{Binding SelectedBackupSet}"
                                  GridViewColumnHeader.Click="GridViewColumnHeader_Click"
                                  CheckBox.Checked="BackupSetCheckBox_Changed"
                                  CheckBox.Unchecked="BackupSetCheckBox_Changed"
                                  PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                                  MouseMove="DragSource_MouseMove"
                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  Visibility="{Binding IsBackupSetTableVisible, Converter={StaticResource BoolToVis}}"
                                  MouseDoubleClick="BackupSetList_MouseDoubleClick">
                            <ListView.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding NavigateToBackupSetCommand}" />
                            </ListView.InputBindings>
                            <ListView.View>
                                <GridView>
                                    <!-- Checkbox column for multi-set restore selection -->
                                    <GridViewColumn Width="28">
                                        <GridViewColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding DataContext.AreAllBackupSetsChecked,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                          IsThreeState="True"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          ToolTip="Select / deselect all"/>
                                            </DataTemplate>
                                        </GridViewColumn.HeaderTemplate>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsCheckedForRestore, Mode=TwoWay}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <!-- Icon column for backup sets, dimmed for off-volume sets -->
                                    <GridViewColumn Width="32">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image Width="16" Height="16" Source="{Binding Icon}"
                                                       Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityIcon}}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Set #" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IndexDisplay}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Description" Width="180">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Files" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FileCountFormatted}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Filtered" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FilteredFileCountFormatted}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Selected" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SelectedFileCountFormatted}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Size" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TotalSizeFormatted}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Created" Width="130">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CreatedOnFormatted}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Inc?" Width="45">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IncrementalDisplay}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Block" Width="60">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BlockSize}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Hash" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding HashAlgorithm}"
                                                           Opacity="{Binding IsOnCurrentVolume, Converter={StaticResource BoolToOpacityText}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                            <ListView.ContextMenu>
                                <StaticResource ResourceKey="RestoreContextMenu"/>
                            </ListView.ContextMenu>
                        </ListView>
                    </Grid>
                </GroupBox>

                <!-- Backup Progress Overlay (covers only tree + content, not log pane) -->
                <Grid Grid.RowSpan="3" 
                      Background="#80000000"
                      Visibility="{Binding IsBackupInProgress, Converter={StaticResource BoolToVis}}">
                    <Border Background="White" 
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="350">
                        <StackPanel>
                            <TextBlock Text="{Binding BusyMessage}" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <ProgressBar Value="{Binding BackupProgressPercent}" 
                                         Maximum="100"
                                         Height="24" 
                                         Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding BackupProgressText}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <TextBlock Text="{Binding CurrentBackupFile}"
                                       HorizontalAlignment="Center"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="300"
                                       Margin="0,0,0,16"/>

                            <Button Content="Abort Backup" 
                                    Command="{Binding AbortBackupCommand}"
                                    HorizontalAlignment="Center"
                                    Width="100"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Restore/Validate/Verify Progress Overlay (covers only tree + content, not log pane) -->
                <Grid Grid.RowSpan="3" 
                      Background="#80000000"
                      Visibility="{Binding IsRestoreInProgress, Converter={StaticResource BoolToVis}}">
                    <Border Background="White" 
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="350">
                        <StackPanel>
                            <TextBlock Text="{Binding BusyMessage}" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <ProgressBar Value="{Binding RestoreProgressPercent}" 
                                         Maximum="100"
                                         Height="24" 
                                         Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding RestoreProgressText}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>

                            <TextBlock Text="{Binding CurrentRestoreFile}"
                                       HorizontalAlignment="Center"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="300"
                                       Margin="0,0,0,16"/>

                            <Button Content="Abort" 
                                    Command="{Binding AbortRestoreCommand}"
                                    HorizontalAlignment="Center"
                                    Width="100"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- TOC Load Overlay — shown while reading TOC, cancellable for blank/new media -->
                <Grid Grid.RowSpan="3"
                      Background="#80000000"
                      Visibility="{Binding IsTOCLoadInProgress, Converter={StaticResource BoolToVis}}">
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="350">
                        <StackPanel>
                            <TextBlock Text="{Binding BusyMessage}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <ProgressBar IsIndeterminate="True"
                                         Height="24"
                                         Margin="0,0,0,16"/>

                            <Button Content="Cancel"
                                    Command="{Binding AbortTOCLoadCommand}"
                                    IsEnabled="{Binding IsTOCCancelEnabled}"
                                    HorizontalAlignment="Center"
                                    Width="100"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        
        <!-- Splitter for Log Pane -->
        <GridSplitter Grid.Row="2" Height="4" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Center"
                      Background="LightGray" />
        
        <!-- Log/Message Pane -->
        <GroupBox Grid.Row="3" Header="{Binding LogPaneHeader}" Margin="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="LogFilterColumn" Width="80"/>
                </Grid.ColumnDefinitions>

                <!-- Log list (binds to ICollectionView for severity filtering) -->
                <ListBox ItemsSource="{Binding LogMessagesView}"
                         x:Name="LogListBox"
                         Grid.Column="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         SelectionMode="Extended"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.ScrollChanged="LogScrollViewer_ScrollChanged"
                         HorizontalContentAlignment="Stretch"
                         Style="{StaticResource VirtualizedListBoxStyle}">
                    <ListBox.CommandBindings>
                        <CommandBinding Command="ApplicationCommands.Copy"
                                        Executed="LogCopy_Executed"
                                        CanExecute="LogCopy_CanExecute"/>
                    </ListBox.CommandBindings>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="_Copy" Command="ApplicationCommands.Copy"/>
                            <Separator/>
                            <MenuItem Header="_Auto-scroll"
                                      IsCheckable="True"
                                      IsChecked="{Binding IsAutoScrollEnabled}"/>
                            <MenuItem Header="Show _Timestamps"
                                      IsCheckable="True"
                                      IsChecked="{Binding ShowTimestamps}"/>
                            <Separator/>
                            <MenuItem Header="_Filter Log" Command="{Binding FocusLogFilterCommand}"/>
                            <Separator/>
                            <MenuItem Header="_Save Log to File…" Command="{Binding SaveLogCommand}"/>
                            <MenuItem Header="{Binding MirrorLogMenuHeader}" Command="{Binding MirrorLogCommand}"/>
                            <Separator/>
                            <MenuItem Header="_Clear Log" Command="{Binding ClearLogCommand}"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:LogEntry}">
                            <TextBlock TextTrimming="CharacterEllipsis">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{x:Static converters:LogDisplayTextConverter.Instance}">
                                        <Binding/><!-- LogEntry -->
                                        <Binding Path="DataContext.ShowTimestamps"
                                                 RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.ToolTip>
                                    <MultiBinding Converter="{x:Static converters:LogDisplayTextConverter.Instance}">
                                        <Binding/><!-- LogEntry -->
                                        <Binding Path="DataContext.ShowTimestamps"
                                                 RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                    </MultiBinding>
                                </TextBlock.ToolTip>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <!-- Sub-bullets: indent, keep default color -->
                                            <DataTrigger Binding="{Binding IsSub}" Value="True">
                                                <Setter Property="Margin" Value="16,0,0,0"/>
                                            </DataTrigger>
                                            <!-- Level-based coloring (only for non-sub entries) -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Level}" Value="{x:Static models:WarningLevel.Error}"/>
                                                    <Condition Binding="{Binding IsSub}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource WarningFg.Error}" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Level}" Value="{x:Static models:WarningLevel.Failed}"/>
                                                    <Condition Binding="{Binding IsSub}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource WarningFg.Failed}" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Level}" Value="{x:Static models:WarningLevel.Warning}"/>
                                                    <Condition Binding="{Binding IsSub}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource WarningFg.Warning}" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Level}" Value="{x:Static models:WarningLevel.Info}"/>
                                                    <Condition Binding="{Binding IsSub}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource WarningFg.Info}" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Level}" Value="{x:Static models:WarningLevel.Completed}"/>
                                                    <Condition Binding="{Binding IsSub}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource WarningFg.Completed}" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Splitter between log list and filter sub-pane (snaps to full / checkboxes / hidden) -->
                <controls:SnappingGridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="LightGray"
                              ResizeDirection="Columns"
                              TargetIndex="2">
                    <controls:SnappingGridSplitter.SnapZones>
                        <!-- Hidden: catches everything from 0 up to 12px -->
                        <controls:SnapZone Value="0"  LowerRange="9999" UpperRange="12"/>
                        <!-- Checkboxes only: catches 12–42px range -->
                        <controls:SnapZone Value="24" LowerRange="12"   UpperRange="18"/>
                        <!-- Free-range zone: 34–68px — no snap, user picks any width -->
                        <!-- Fully shown (natural width): catches 12px below measured width and above -->
                        <controls:SnapZone IsAutoSize="True" LowerRange="12" UpperRange="9999"/>
                    </controls:SnappingGridSplitter.SnapZones>
                </controls:SnappingGridSplitter>

                <!-- Severity filter checkboxes sub-pane -->
                <StackPanel Grid.Column="2" Margin="4,2,2,2"
                            x:Name="LogFilterPanel">
                    <TextBlock Text="Log Filter" Margin="0,0,0,4"/>
                    <!-- Info (covers None + Info) — blue checkbox -->
                    <CheckBox IsChecked="{Binding ShowLogInfo}" Margin="0,1"
                              x:Name="LogFilterInfoCheckBox">
                        <CheckBox.Background>
                            <!-- Notice: use the same colors as in WarningBg.Info etc. brushes, s. App.xaml -->
                            <SolidColorBrush Color="#FFCCE5FF"/>
                        </CheckBox.Background>
                        <CheckBox.Content>
                            <TextBlock Text="ℹ Info" FontSize="11"
                                       Foreground="{StaticResource WarningFg.Info}"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <!-- Completed — green checkbox -->
                    <CheckBox IsChecked="{Binding ShowLogCompleted}" Margin="0,1">
                        <CheckBox.Background>
                            <SolidColorBrush Color="#FFCCFFCC"/>
                        </CheckBox.Background>
                        <CheckBox.Content>
                            <TextBlock Text="✓ Completed" FontSize="11"
                                       Foreground="{StaticResource WarningFg.Completed}"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <!-- Warning — orange checkbox -->
                    <CheckBox IsChecked="{Binding ShowLogWarning}" Margin="0,1">
                        <CheckBox.Background>
                            <SolidColorBrush Color="#FFFFF0CC"/>
                        </CheckBox.Background>
                        <CheckBox.Content>
                            <TextBlock Text="⚠ Warning" FontSize="11"
                                       Foreground="{StaticResource WarningFg.Warning}"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <!-- Error (covers Error + Failed) — red checkbox -->
                    <CheckBox IsChecked="{Binding ShowLogError}" Margin="0,1">
                        <CheckBox.Background>
                            <SolidColorBrush Color="#FFFFCCCC"/>
                        </CheckBox.Background>
                        <CheckBox.Content>
                            <TextBlock Text="⚠ Error" FontSize="11"
                                       Foreground="{StaticResource WarningFg.Error}"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <!-- Sub-detail entries (IsSub) — no colored background -->
                    <Separator Margin="0,3,0,2"/>
                    <CheckBox IsChecked="{Binding ShowLogDetails}" Margin="0,1"
                              Content="Details" FontSize="11"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Visibility="{Binding IsIoSpeedVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Virtual IO:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox ItemsSource="{Binding IoSpeedOptions}"
                              SelectedItem="{Binding SelectedIoSpeed}"
                              IsEnabled="{Binding IsIoSpeedEnabled}"
                              Width="180" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="150" Height="16" 
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </StatusBarItem>
        </StatusBar>
        
        <!-- General Busy Overlay (only for non-backup operations) -->
        <Grid Grid.RowSpan="5" 
              Background="#40000000"
              Visibility="{Binding IsGeneralBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Notice: IsIndeterminate bound to IsBusy - stops animation when overlay is hidden -->
                <ProgressBar IsIndeterminate="{Binding IsGeneralBusy}" Width="200" Height="20" />
                <TextBlock Text="{Binding BusyMessage}" 
                           Foreground="White" 
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
