<Window x:Class="TapeWinNET.ConnectToRemoteHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        d:DataContext="{d:DesignInstance Type=vm:ConnectToRemoteHostViewModel}"
        mc:Ignorable="d"
        Title="Connect to Remote Host"
        Height="300" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Progress bar fill color -->
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="Blue"/>
        </Style>        
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Host / Port fields -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:"
                       VerticalAlignment="Center" Margin="0,0,8,6"/>
            <TextBox   Grid.Row="0" Grid.Column="1"
                       Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                       IsEnabled="{Binding IsHostEditable}"
                       Margin="0,0,0,6"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox   Grid.Row="1" Grid.Column="1"
                       Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Example hint text, same style as BackupWindow.xaml -->
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                       Text="Examples: 192.168.178.22, tape-server, tape-server.local"
                       FontSize="10" Foreground="DarkGray"
                       Margin="0,4,0,0"/>
        </Grid>

        <!-- Checkboxes -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <CheckBox Content="Use _local host (127.0.0.1)"
                      IsChecked="{Binding UseLocalHost}"
                      Margin="0,0,0,4"/>
            <CheckBox Content="Use _secure connection (TLS)"
                      IsChecked="{Binding UseTls}"/>
        </StackPanel>

        <!-- Connecting indicator -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <ProgressBar IsIndeterminate="True" Width="120" Height="14" Margin="0,0,8,0"/>
            <TextBlock Text="Connecting…" VerticalAlignment="Center" FontStyle="Italic"/>
        </StackPanel>

        <!-- Error / status panel — WarningPanelStyle handles visibility via {Binding WarningLevel} -->
        <Border Grid.Row="3" Style="{StaticResource WarningPanelStyle}" VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding WarningLevel, Converter={x:Static converters:WarningLevelToIconConverter.Instance}}"
                           FontSize="13" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    Width="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Connect" Command="{Binding ConnectCommand}"
                    Width="80" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
