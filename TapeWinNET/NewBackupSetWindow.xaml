<Window x:Class="TapeWinNET.NewBackupSetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        d:DataContext="{d:DesignInstance Type=vm:NewBackupSetViewModel}"
        mc:Ignorable="d"
        Title="New Backup Set"
        Height="700" Width="1100"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BooleanToVisibilityCollapsedConverter x:Key="BoolToVis" />
        
        <!-- Warning panel styles -->
        <Style x:Key="WarningPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Danger">
                    <Setter Property="Background" Value="#FFFFCCCC"/>
                    <Setter Property="BorderBrush" Value="#FFCC0000"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Warning">
                    <Setter Property="Background" Value="#FFFFF0CC"/>
                    <Setter Property="BorderBrush" Value="#FFCC9900"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Info">
                    <Setter Property="Background" Value="#FFCCFFCC"/>
                    <Setter Property="BorderBrush" Value="#FF00CC00"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding RemoveSelectedCommand}"/>
        <KeyBinding Key="OemPlus" Command="{Binding AddFilesCommand}"/>
        <KeyBinding Key="Add" Command="{Binding AddFilesCommand}"/>
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding AddFolderCommand}"/>
        <KeyBinding Key="Add" Modifiers="Control" Command="{Binding AddFolderCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="350" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left Pane: Files to Backup -->
            <GroupBox Grid.Column="0" Header="Files to Backup" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Add Buttons and Pattern Input Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="Add Files..." 
                                Command="{Binding AddFilesCommand}" 
                                Width="80" Margin="0,0,4,0" 
                                ToolTip="Add files (keyboard: +)"/>
                        <Button Grid.Column="1" Content="Add Folder..." 
                                Command="{Binding AddFolderCommand}" 
                                Width="90" Margin="0,0,8,0" 
                                ToolTip="Add folder (keyboard: Ctrl++)"/>
                        <TextBlock Grid.Column="2" Text="Add Patterns:" 
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <TextBox Grid.Column="3" 
                                 Text="{Binding PatternInput, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,4,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddPatternsCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="4" Content="+" 
                                Command="{Binding AddPatternsCommand}" 
                                Width="28" ToolTip="Add patterns (Enter)"/>
                    </Grid>

                    <!-- Help text - right aligned under pattern input -->
                    <TextBlock Grid.Row="1" 
                               Text="Separate patterns with ;  Use * and ?  Example: C:\Docs\*.doc?; D:\Projects\MyApp\"
                               FontSize="10" Foreground="DarkGray" 
                               HorizontalAlignment="Right"
                               Margin="0,0,0,8"/>

                    <!-- Files List -->
                    <ListView Grid.Row="2" 
                              ItemsSource="{Binding SourceEntries}"
                              SelectedItem="{Binding SelectedSourceEntry}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <!-- Checkbox column -->
                                <GridViewColumn Width="30">
                                    <GridViewColumn.Header>
                                        <CheckBox IsChecked="{Binding DataContext.SelectAll, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  Command="{Binding DataContext.SelectAllCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  ToolTip="Select/Deselect All"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <!-- Icon column -->
                                <GridViewColumn Width="28">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Width="16" Height="16" Source="{Binding Icon}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Path / Pattern" Width="280" 
                                                DisplayMemberBinding="{Binding Pattern}"/>
                                <GridViewColumn Header="Files" Width="80" 
                                                DisplayMemberBinding="{Binding FileCountDisplay}"/>
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </Grid>
            </GroupBox>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch"
                          Background="LightGray"/>

            <!-- Right Pane: Options -->
            <Grid Grid.Column="2" Margin="4,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Backup Set Options -->
                <GroupBox Grid.Row="0" Header="Backup Set Options">
                    <StackPanel Margin="8">
                        <TextBlock Text="Description:" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,0,0,12"/>

                        <CheckBox Content="Include subdirectories" 
                                  IsChecked="{Binding IncludeSubdirectories}"
                                  Margin="0,0,0,4"/>
                        <CheckBox Content="Incremental backup" 
                                  IsChecked="{Binding IncrementalBackup}"
                                  Margin="0,0,0,4"/>
                        <CheckBox Content="Use filemarks (advanced)" 
                                  IsChecked="{Binding UseFilemarks}"
                                  Margin="0,0,0,4"/>
                        <CheckBox Content="Preview files before backup" 
                                  IsChecked="{Binding PreviewFilesBeforeBackup}"
                                  Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Block size:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{x:Static vm:NewBackupSetViewModel.BlockSizeOptions}"
                                      SelectedIndex="{Binding SelectedBlockSizeIndex}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Hash:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{x:Static vm:NewBackupSetViewModel.HashOptions}"
                                      SelectedIndex="{Binding SelectedHashIndex}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Append Options -->
                <GroupBox Grid.Row="1" Header="Append Options" Margin="0,8,0,0">
                    <StackPanel Margin="8">
                        <RadioButton Content="Append after set:" 
                                     IsChecked="{Binding AppendToSet}"
                                     Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AppendOptions}"
                                  SelectedItem="{Binding SelectedAppendOption}"
                                  DisplayMemberPath="DisplayText"
                                  IsEnabled="{Binding AppendToSet}"
                                  Margin="20,0,0,8"/>

                        <RadioButton Content="Overwrite entire media" 
                                     IsChecked="{Binding OverwriteMedia}"/>

                        <!-- Warning Panel -->
                        <Border Style="{StaticResource WarningPanelStyle}">
                            <TextBlock Text="{Binding WarningMessage}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Preview Section -->
                <GroupBox Grid.Row="2" Header="Preview" Margin="0,8,0,0">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Total files:" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalFileCountDisplay}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total size:" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalSizeDisplay}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Last scan:" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastScanTimeDisplay}"/>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <Button Content="Scan Now" Command="{Binding ScanNowCommand}" 
                                    Width="80" Margin="0,0,8,0"/>
                            <CheckBox Content="Auto-scan" IsChecked="{Binding AutoScan}" 
                                      VerticalAlignment="Center"/>
                            <ProgressBar Width="60" Height="16" Margin="8,0,0,0"
                                         IsIndeterminate="{Binding IsScanning}"
                                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- Bottom Button Bar -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}" 
                        Width="110"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}" 
                        Width="80" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="{Binding StartBackupButtonText}" 
                        Command="{Binding StartBackupCommand}" 
                        Width="100" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>