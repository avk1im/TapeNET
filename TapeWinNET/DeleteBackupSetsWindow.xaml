<Window x:Class="TapeWinNET.DeleteBackupSetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
        xmlns:converters="clr-namespace:TapeWinNET.Converters"
        xmlns:controls="clr-namespace:TapeWinNET.Controls"
        xmlns:help="clr-namespace:TapeWinNET.Help"
        d:DataContext="{d:DesignInstance Type=vm:DeleteBackupSetsViewModel}"
        mc:Ignorable="d"
        Title="Delete Backup Sets"
        Height="350" Width="450"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <!-- Outer grid: column 0 = dialog content, column 1 = splitter, column 2 = help pane. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>                                       <!-- help splitter -->
            <ColumnDefinition x:Name="HelpPaneColumn" Width="0" MinWidth="0"/>    <!-- help pane    -->
        </Grid.ColumnDefinitions>

        <!-- Dialog content fills column 0 -->
        <Grid x:Name="HelpOverlayRoot" Grid.Column="0" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Delete from set -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12"
                    help:HelpControlNameAttachedProperty.ControlName="Delete from set">
            <TextBlock Text="Delete from set:" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding DeleteOptions}"
                      SelectedItem="{Binding SelectedOption}"
                      DisplayMemberPath="DisplayText"/>
        </StackPanel>

        <!-- Warning panel -->
        <Border Grid.Row="1" Style="{StaticResource WarningPanelStyle}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding WarningLevel, Converter={x:Static converters:WarningLevelToIconConverter.Instance}}"
                           FontSize="13" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding WarningMessage}" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Statistics -->
        <GroupBox Grid.Row="2" Header="Preview" VerticalAlignment="Top"
                  help:HelpControlNameAttachedProperty.ControlName="Preview">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Media capacity:" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MediaCapacityDisplay}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Remaining:" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MediaRemainingDisplay}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="To delete:" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeleteSizeDisplay}" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Remaining after delete:" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RemainingAfterDeleteDisplay}" FontWeight="SemiBold"/>
            </Grid>
        </GroupBox>

        <!-- Media usage bar — shows existing sets with the deletion range
             highlighted in red. Click a preserved set to make it the first
             to delete; click the red zone or free space to shrink the range. -->
        <controls:MediaUsageBarControl
            Grid.Row="3"
            Margin="0,0,0,12"
            FreeIsInteractive="True"
            Segments="{Binding UsageBar.Segments}"
            TotalCapacity="{Binding UsageBar.TotalCapacity}"
            SegmentClickCommand="{Binding UsageBar.SegmentClickCommand}"/>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="HelpButton" Content="_Help ▶" Click="HelpButton_Click"
                        MinWidth="60" Padding="10,1"
                        ToolTip="Open help for this dialog (F1)"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Width="80" Margin="0,0,8,0" IsCancel="True" IsDefault="True"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}"
                        Width="80" Foreground="{DynamicResource WarningFg.Error}"
                        help:HelpControlNameAttachedProperty.ControlName="Delete button"/>
            </StackPanel>
        </Grid>
        </Grid><!-- end dialog-content Grid (column 0) -->

        <!-- Help splitter — visible only when the help pane is open -->
        <GridSplitter x:Name="HelpPaneSplitter"
                      Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="LightGray"
                      Visibility="Collapsed"/>

        <!-- Help pane — width driven by HelpPaneColumn; starts at 0 (hidden) -->
        <controls:HelpPane x:Name="HelpPaneControl"
                           Grid.Column="2"
                           DataContext="{x:Null}"
                       Visibility="Collapsed"/>

    </Grid>
</Window>
