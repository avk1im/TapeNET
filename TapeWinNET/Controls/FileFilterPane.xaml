<UserControl x:Class="TapeWinNET.Controls.FileFilterPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:TapeWinNET.Converters"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="60" d:DesignWidth="600">

    <UserControl.Resources>
        <converters:BoolToVisibilityCollapsedConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <StackPanel Margin="4,4,4,0">
        <!-- Filter bar row -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Toggle Apply / Disable button -->
            <Button Grid.Column="0"
                    Command="{Binding ToggleFilterCommand, ElementName=Root}"
                    Width="60" Margin="0,0,4,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Apply"/>
                        <Setter Property="ToolTip" Value="Apply filter"/>
                        <Setter Property="IsEnabled" Value="{Binding CanApplyFilter, ElementName=Root}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterActive, ElementName=Root}" Value="True">
                                <Setter Property="Content" Value="Disable"/>
                                <Setter Property="ToolTip" Value="Disable the active filter (keeps definition)"/>
                                <Setter Property="IsEnabled" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Pattern text / advanced summary -->
            <TextBox Grid.Column="1"
                     Text="{Binding FilterText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding HasAdvancedFilter, ElementName=Root}"
                     VerticalContentAlignment="Center"
                     Margin="0,0,4,0">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <!-- Gray italic when showing advanced summary (read-only) -->
                            <DataTrigger Binding="{Binding HasAdvancedFilter, ElementName=Root}" Value="True">
                                <Setter Property="FontStyle" Value="Italic"/>
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.InputBindings>
                    <KeyBinding Key="Return"
                                Command="{Binding ToggleFilterCommand, ElementName=Root}"/>
                </TextBox.InputBindings>
            </TextBox>

            <!-- Filter status text -->
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="4,0,8,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text">
                            <Setter.Value>
                                <MultiBinding StringFormat="{}{0:N0} of {1:N0} file(s)">
                                    <Binding Path="FilteredCount" ElementName="Root"/>
                                    <Binding Path="TotalCount" ElementName="Root"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterActive, ElementName=Root}" Value="False">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <Binding Path="TotalCount" ElementName="Root" StringFormat="{}{0:N0} file(s)"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Advanced filter button -->
            <Button Grid.Column="3"
                    Command="{Binding AdvancedFilterCommand, ElementName=Root}"
                    Padding="6,0" Margin="0,0,0,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Advanced&#x2026;"/>
                        <Setter Property="ToolTip" Value="Open the advanced filter editor"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasAdvancedFilter, ElementName=Root}" Value="True">
                                <Setter Property="Content" Value="Advanced &#x25CF;"/>
                                <Setter Property="ToolTip" Value="{Binding AdvancedFilterTooltip, ElementName=Root}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Help text / pattern explanation -->
        <TextBlock FontSize="10" Foreground="DarkGray" Margin="64,2,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text"
                            Value="Separate patterns with ;   Use * and ?   Example: *.doc?; C:\Projects\MyApp\"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAdvancedFilter, ElementName=Root}" Value="True">
                            <Setter Property="Text" Value="Advanced filter active &#x2014; click Advanced to edit"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </StackPanel>
</UserControl>
