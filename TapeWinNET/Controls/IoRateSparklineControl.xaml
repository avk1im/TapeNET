<UserControl x:Class="TapeWinNET.Controls.IoRateSparklineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="300">

    <!-- Outer border to frame the chart, matching MediaUsageBarControl aesthetic -->
    <Border BorderBrush="#FFAAAAAA" BorderThickness="1" Margin="0">
        <Grid>
            <!-- Drawing canvas - Polygon and Polyline are added in code-behind -->
            <Canvas x:Name="SparklineCanvas"
                    ClipToBounds="True"
                    Background="White"/>

            <!-- Y-axis peak label pinned to top-left (scale annotation, same grey as border) -->
            <TextBlock x:Name="AxisPeakLabel"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="3,1,0,0"
                       FontFamily="Consolas"
                       FontSize="9"
                       Foreground="#FFAAAAAA"/>

            <!-- Current-rate label pinned to top-right (accent blue, matches polyline) -->
            <TextBlock x:Name="PeakLabel"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,1,3,0"
                       FontFamily="Consolas"
                       FontSize="9"/>
        </Grid>
    </Border>

</UserControl>
