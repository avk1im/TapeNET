<UserControl x:Class="TapeWinNET.Controls.HelpPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:TapeWinNET.ViewModels"
             xmlns:controls="clr-namespace:TapeWinNET.Controls"
             xmlns:converters="clr-namespace:TapeWinNET.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HelpPaneViewModel}"
             MinWidth="260">

    <UserControl.Resources>
        <converters:BoolToVisibilityCollapsedConverter  x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityCollapsedConverter x:Key="InverseBoolToVis"/>
        <converters:NullToVisibilityCollapsedConverter  x:Key="NullToVis"/>
        <converters:CountToVisibilityConverter          x:Key="CountToVis"/>
        <converters:CountToBoolConverter                x:Key="CountToBool"/>
        <converters:ConversationRoleToVisibilityConverter x:Key="RoleToVis"/>

        <!-- Suggestion chip -->
        <Style x:Key="TopicChipStyle" TargetType="Button">
            <Setter Property="Margin"   Value="2"/>
            <Setter Property="Padding"  Value="6,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor"   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource WarningBg.Completed}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button chip -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TopicChipStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource WarningBg.Warning}"
                                BorderBrush="{StaticResource WarningBr.Warning}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Conversation item template -->
        <DataTemplate x:Key="ConversationItemTemplate" DataType="{x:Type vm:ConversationItem}">
            <StackPanel>
                <!-- User query bubble -->
                <Border Margin="32,4,4,4" Padding="8,4" CornerRadius="8"
                        Background="{StaticResource WarningBg.Info}"
                        HorizontalAlignment="Right"
                        Visibility="{Binding Role, Converter={StaticResource RoleToVis},
                                     ConverterParameter=User}">
                    <TextBlock Text="{Binding PlainText}" TextWrapping="Wrap" FontStyle="Italic"/>
                </Border>

                <!-- Assistant answer bubble -->
                <Border Margin="4,4,32,0" Padding="8,4" CornerRadius="8"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                        HorizontalAlignment="Left" MaxWidth="600"
                        Visibility="{Binding Role, Converter={StaticResource RoleToVis},
                                     ConverterParameter=Assistant}">
                    <!-- RichTextBox instead of FlowDocumentScrollViewer: see ContentViewer comment.
                         Document is pushed in code-behind via the Loaded EventSetter because
                         RichTextBox.Document is not a bindable DP. -->
                    <RichTextBox IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Segoe UI" FontSize="12">
                        <RichTextBox.Style>
                            <Style TargetType="RichTextBox">
                                <EventSetter Event="Loaded"
                                             Handler="ChatRichTextBox_Loaded"/>
                                <EventSetter Event="PreviewMouseLeftButtonDown"
                                             Handler="RichTextBox_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="PreviewMouseMove"
                                             Handler="RichTextBox_PreviewMouseMove"/>
                                <EventSetter Event="MouseLeave"
                                             Handler="RichTextBox_MouseLeave"/>
                            </Style>
                        </RichTextBox.Style>
                    </RichTextBox>
                </Border>

                <!-- Suggested topic chips (assistant only) -->
                <ItemsControl ItemsSource="{Binding SuggestedTopics}"
                              Margin="4,2,32,0"
                              Visibility="{Binding SuggestedTopics.Count,
                                           Converter={StaticResource CountToVis},
                                           Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource TopicChipStyle}"
                                    Content="{Binding Title}"
                                    Command="{Binding DataContext.NavigateTopicRefCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Suggested action buttons (assistant only) -->
                <ItemsControl ItemsSource="{Binding SuggestedActions}"
                              Margin="4,2,32,4"
                              Visibility="{Binding SuggestedActions.Count,
                                           Converter={StaticResource CountToVis},
                                           Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Content="{Binding DisplayName}"
                                    Command="{Binding DataContext.InvokeActionCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <!-- ── Header strip ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="4,3">
            <DockPanel LastChildFill="True">

                <!-- Close button -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding CloseCommand}"
                        ToolTip="Close Help"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Padding="4,2" Margin="2,0,0,0">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               IsHitTestVisible="False"/>
                </Button>

                <!-- AI badge / setup button -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding OpenAiSetupCommand}"
                        ToolTip="{Binding AssistantModeBadge}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Padding="4,2" Margin="0,0,2,0">
                    <TextBlock Text="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               IsHitTestVisible="False"/>
                </Button>

                <!-- Nav buttons: Back / Forward / Home -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Command="{Binding BackCommand}" ToolTip="Back"
                            Style="{StaticResource ToolbarButtonStyle}" Padding="4,2">
                        <TextBlock Text="&#xE830;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   IsHitTestVisible="False"/>
                    </Button>
                    <Button Command="{Binding ForwardCommand}" ToolTip="Forward"
                            Style="{StaticResource ToolbarButtonStyle}" Padding="4,2">
                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   IsHitTestVisible="False"/>
                    </Button>
                    <Button Command="{Binding HomeCommand}" ToolTip="Help Home"
                            Style="{StaticResource ToolbarButtonStyle}" Padding="4,2" Margin="4,0,0,0">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   IsHitTestVisible="False"/>
                    </Button>
                </StackPanel>

                <!-- Search box -->
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" Margin="4,0"
                         ToolTip="Search help topics…"/>
            </DockPanel>
        </Border>

        <!-- Search suggestions popup (anchored to header) -->
        <Popup x:Name="SearchPopup"
               IsOpen="{Binding SearchSuggestions.Count,
                        Converter={StaticResource CountToBool},
                        Mode=OneWay}"
               PlacementTarget="{Binding ElementName=SearchBox}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               MinWidth="240">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" MaxHeight="200">
                <ListBox x:Name="SuggestionListBox"
                         ItemsSource="{Binding SearchSuggestions}"
                         DisplayMemberPath="Topic.Title"
                         MouseLeftButtonUp="SearchSuggestion_Selected"/>
            </Border>
        </Popup>

        <!-- ── Bottom button strip ───────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="4,3">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Command="{Binding ClearChatCommand}"
                        Content="Clear Chat" Padding="6,2" FontSize="11"
                        ToolTip="Clear conversation history"/>
                <Button DockPanel.Dock="Right"
                        Content="Guide Me" IsEnabled="False"
                        Padding="6,2" FontSize="11" Margin="4,0,0,0"
                        ToolTip="Interactive walkthroughs — coming soon"/>
                <Button DockPanel.Dock="Right"
                        Content="Reveal" IsEnabled="False"
                        Padding="6,2" FontSize="11"
                        ToolTip="Reveal controls — coming soon"/>
            </DockPanel>
        </Border>

        <!-- ── Main body: content / splitter / chat ──────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ContentRow" Height="*" MinHeight="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="ChatRow"    Height="200" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Content subpane.
                 RichTextBox is used instead of FlowDocumentScrollViewer because FDSV's internal
                 TextEditor captures all mouse input for text selection before Hyperlink.Click can
                 ever fire. RichTextBox with IsReadOnly="True" correctly surfaces interactive
                 elements: the cursor becomes a hand over links and Hyperlink.Click bubbles normally.
                 Document is set in code-behind (ContentViewer.Document) because RichTextBox.Document
                 is not a bindable dependency property. -->
            <RichTextBox x:Name="ContentViewer"
                         Grid.Row="0"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Segoe UI" FontSize="12"
                         PreviewMouseLeftButtonDown="RichTextBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="RichTextBox_PreviewMouseMove"
                         MouseLeave="RichTextBox_MouseLeave"/>

            <!-- Splitter between content and chat -->
            <GridSplitter x:Name="ChatSplitter"
                          Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="LightGray"
                          DragCompleted="ChatSplitter_DragCompleted"/>

            <!-- Chat subpane -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Conversation list -->
                <ScrollViewer Grid.Row="0" x:Name="ConversationScroller"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ConversationItems}"
                                  ItemTemplate="{StaticResource ConversationItemTemplate}"/>
                </ScrollViewer>

                <!-- Input row -->
                <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="4">
                    <DockPanel LastChildFill="True">
                        <!-- Ask / Abort button: shows stop icon while thinking, Ask label otherwise -->
                        <Button DockPanel.Dock="Right"
                                Command="{Binding AskCommand}"
                                Padding="8,2" Margin="4,0,0,0"
                                MinWidth="40"
                                ToolTip="{Binding AskButtonTooltip}"
                                Content="{Binding AskButtonContent}"/>
                        <!-- Pulsing star animation shown in front of the input while thinking -->
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding ThinkingAnimationText}"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Width="20"
                                   TextAlignment="Center"
                                   Margin="0,0,4,0"
                                   Visibility="{Binding IsAsking, Converter={StaticResource BoolToVis}}"/>
                        <TextBox Text="{Binding PendingQuery, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 ToolTip="Ask a question about TapeWin…"
                                 KeyDown="ChatInput_KeyDown"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
