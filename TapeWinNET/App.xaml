<Application x:Class="TapeWinNET.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TapeWinNET"
             xmlns:converters="clr-namespace:TapeWinNET.Converters"
             xmlns:models="clr-namespace:TapeWinNET.Models"
             xmlns:services="clr-namespace:TapeLibNET.Services;assembly=tapelib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Default style for all Windows - sets application icon -->
            <!-- Note: Icon is also set programmatically in App.xaml.cs via TapeIcons.GetTapeDriveIcon() -->
            <!-- Uncomment below to use an .ico file from Resources folder: -->
            <!--
            <Style TargetType="Window">
                <Setter Property="Icon" Value="/Resources/tape_drive.ico"/>
            </Style>
            -->

            <!-- Common styles -->
            <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            </Style>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- Centralized warning level colors                           -->
            <!-- ═══════════════════════════════════════════════════════════ -->

            <!-- Background / border brushes for warning panels -->
            <SolidColorBrush x:Key="WarningBg.Error"     Color="#FFFFCCCC"/>
            <SolidColorBrush x:Key="WarningBr.Error"     Color="#FFCC0000"/>
            <SolidColorBrush x:Key="WarningBg.Warning"   Color="#FFFFF0CC"/>
            <SolidColorBrush x:Key="WarningBr.Warning"   Color="#FFCC9900"/>
            <SolidColorBrush x:Key="WarningBg.Failed"    Color="#FFFFDDD0"/>
            <SolidColorBrush x:Key="WarningBr.Failed"    Color="#FFCC4400"/>
            <SolidColorBrush x:Key="WarningBg.Info"      Color="#FFCCE5FF"/>
            <SolidColorBrush x:Key="WarningBr.Info"      Color="#FF3399CC"/>
            <SolidColorBrush x:Key="WarningBg.Completed" Color="#FFCCFFCC"/>
            <SolidColorBrush x:Key="WarningBr.Completed" Color="#FF00CC00"/>

            <!-- Foreground brushes for log pane text -->
            <SolidColorBrush x:Key="WarningFg.Error"     Color="Red"/>
            <SolidColorBrush x:Key="WarningFg.Warning"   Color="Orange"/>
            <SolidColorBrush x:Key="WarningFg.Failed"    Color="#FFCC4400"/>
            <SolidColorBrush x:Key="WarningFg.Info"      Color="Blue"/>
            <SolidColorBrush x:Key="WarningFg.Completed" Color="Green"/>

            <!-- Shared warning panel style for dialog windows.
                 Bind the DataContext so that WarningLevel (enum) drives visibility + colors,
                 and use WarningLevelToIconConverter for the icon.
                 The panel is Collapsed by default and becomes Visible for any non-None level. -->
            <Style x:Key="WarningPanelStyle" TargetType="Border">
                <Setter Property="Padding" Value="8"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WarningLevel}" Value="{x:Static services:ServiceReportLevel.Error}">
                        <Setter Property="Background" Value="{StaticResource WarningBg.Error}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource WarningBr.Error}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WarningLevel}" Value="{x:Static services:ServiceReportLevel.Warning}">
                        <Setter Property="Background" Value="{StaticResource WarningBg.Warning}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource WarningBr.Warning}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WarningLevel}" Value="{x:Static services:ServiceReportLevel.Failed}">
                        <Setter Property="Background" Value="{StaticResource WarningBg.Failed}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource WarningBr.Failed}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WarningLevel}" Value="{x:Static services:ServiceReportLevel.Info}">
                        <Setter Property="Background" Value="{StaticResource WarningBg.Info}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource WarningBr.Info}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding WarningLevel}" Value="{x:Static services:ServiceReportLevel.Completed}">
                        <Setter Property="Background" Value="{StaticResource WarningBg.Completed}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource WarningBr.Completed}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>