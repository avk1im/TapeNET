# EditorConfig — solution-wide diagnostic severity overrides
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/configuration-options

root = true

[*.cs]

# CS8321 — unused local function
# These are intentional: log-helper families (logOkSub, logWarnSub, etc.) are
# defined as a complete set even if not all variants are called yet.
# Downgraded from Warning to Suggestion so they remain discoverable in the IDE
# but never pollute the build output.
# dotnet_diagnostic.CS8321.severity = suggestion
